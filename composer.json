{
    "name": "seangoogoo/next-posts-block",
    "description": "Query Loop block variation: N posts following the current post in the chosen order, with wrap-around.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.5",
        "wp-coding-standards/wpcs": "^3.0",
        "wp-phpunit/wp-phpunit": "^6.9",
        "yoast/phpunit-polyfills": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "NextPostsBlock\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NextPostsBlock\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "7.4"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite unit",
        "test:integration": "phpunit --configuration phpunit.xml.dist --testsuite integration --bootstrap tests/integration/bootstrap.php",
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist"
    }
}
