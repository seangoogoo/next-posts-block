#. Plugin Name of the plugin
#: next-posts-block.php
msgid "Next Posts — Query Loop Block"
msgstr "Publications suivantes — Bloc Query Loop"

#. Description of the plugin
#: next-posts-block.php
msgid ""
"Query Loop variation that displays posts sequentially relative to the "
"current post, with wrap-around. Supports ordering by date or title."
msgstr ""
"Variation du Query Loop qui affiche les publications séquentiellement par "
"rapport à la publication actuelle, avec retour au début. Tri par date ou par "
"titre."

#. Author of the plugin
#: next-posts-block.php
msgid "Jensen SIU"
msgstr ""

#: build/index.js:1 src/variation.js:16
msgid "Next Posts"
msgstr "Publications suivantes"

#: build/index.js:1 src/variation.js:17
msgid ""
"Displays the N posts that sequentially follow (or precede) the current post, "
"with wrap-around."
msgstr ""
"Affiche les N publications qui suivent (ou précèdent) séquentiellement la "
"publication actuelle, avec retour au début."

#: build/index.js:1 src/variation.js:24
msgid "next"
msgstr "suivant"

#: build/index.js:1 src/variation.js:25
msgid "previous"
msgstr "précédent"

#: build/index.js:1 src/variation.js:26
msgid "sequence"
msgstr "séquence"

#: build/index.js:1 src/variation.js:27
msgid "related"
msgstr "connexe"

#: build/index.js:1 src/inspector-controls.js:48
msgid "Sequential settings"
msgstr "Réglages de séquence"

#: build/index.js:1 src/inspector-controls.js:56
msgid "Exclude sticky posts from the sequence"
msgstr "Exclure les publications épinglées de la séquence"

#: build/index.js:1 src/inspector-controls.js:60
msgid ""
"Sticky posts are removed from the canonical list used to build the sequence."
msgstr ""
"Les publications épinglées sont retirées de la liste canonique utilisée pour "
"construire la séquence."
