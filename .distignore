# .distignore — files excluded from the distribution ZIP (wp-scripts plugin-zip)

# Version control
/.git
/.gitignore

# CI / GitHub
/.github

# Dev dependencies
/node_modules
/vendor

# Source (compiled to build/)
/src

# Tests & tooling
/tests
/bin
/docs
/.phpunit.result.cache
/phpcs.xml.dist
/phpunit.xml.dist

# Package manager manifests
/composer.json
/composer.lock
/package.json
/package-lock.json

# Dev-only docs
README.md
AGENT-HANDOFF.md
CLAUDE.md
